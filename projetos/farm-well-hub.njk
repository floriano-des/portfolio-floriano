              <p class="cs-meta-item__value">Remoto</p>
            </div>
            <div class="cs-meta-item cs-meta-item--result">
              <p class="cs-meta-item__label">Impacto</p>
              <p class="cs-meta-item__value">+100 agricultores inscritos nos primeiros meses</p>
            </div>
