<!DOCTYPE html>
<html lang="pt-BR">
<head>
  {# Template isolado para cases imersivos, sem navegação e rodapé globais. #}
  <meta charset="UTF-8">
  {% include "partials/gtm-head.njk" %}
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/motion-head.njk" %}
  <title>{{ title or metadata.title }}</title>
  <meta name="description" content="{{ description or metadata.description }}">
  <meta name="author" content="{{ metadata.author }}">
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">
  {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}

  <meta property="og:type" content="{{ ogType or 'article' }}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ description or metadata.description }}">
  <meta property="og:image" content="{{ ogImage or metadata.ogImage }}">
  <meta property="og:image:secure_url" content="{{ ogImage or metadata.ogImage }}">
  {% if ogImageType %}<meta property="og:image:type" content="{{ ogImageType }}">{% endif %}
  {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}">{% endif %}
  {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}">{% endif %}
  <meta property="og:image:alt" content="{{ ogImageAlt or title or metadata.title }}">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:site_name" content="{{ metadata.siteName }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or metadata.title }}">
  <meta name="twitter:description" content="{{ description or metadata.description }}">
  <meta name="twitter:image" content="{{ ogImage or metadata.ogImage }}">
  <meta name="twitter:image:alt" content="{{ ogImageAlt or title or metadata.title }}">
  {% include "partials/structured-data.njk" %}
  {% set caseUrl = metadata.url + page.url %}
  {% set caseStudySchema = {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "@id": caseUrl + "#case-study",
    "name": title or metadata.title,
    "headline": title or metadata.title,
    "description": description or metadata.description,
    "url": caseUrl,
    "image": ogImage or metadata.ogImage,
    "inLanguage": "pt-BR",
    "creator": {
      "@id": metadata.url + "/#person"
    },
    "author": {
      "@id": metadata.url + "/#person"
    },
    "isPartOf": {
      "@id": metadata.url + "/#website"
    },
    "mainEntityOfPage": {
      "@id": caseUrl + "#webpage"
    },
    "keywords": [
      "Product Design",
      "UX Research",
      "prototipação com IA",
      "produto digital",
      "Mercado das Figurinhas"
    ]
  } %}
  <script type="application/ld+json">{{ caseStudySchema | json | safe }}</script>

  <link rel="icon" type="image/webp" href="/assets/favicon.webp">
  <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/montserrat-latin-normal.woff2" crossorigin>
  <link rel="preload" as="image" href="{{ heroImage or ogImage }}" fetchpriority="high">
  <link rel="stylesheet" href="/css/reset.css?v={{ '/css/reset.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/vendor.lenis.css?v={{ '/css/vendor.lenis.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.tokens.css?v={{ '/css/style.tokens.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.footer-motion.css?v={{ '/css/style.footer-motion.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.motion.css?v={{ '/css/style.motion.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/case-study-immersive.css?v={{ '/css/case-study-immersive.css' | assetVersion }}">
</head>
<body class="immersive-case-page {{ bodyClass or '' }}">
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K738G4S2"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  {% include "partials/transition-curtain.njk" %}

  <button class="immersive-case-close" type="button" aria-label="Fechar case" data-case-close data-magnetic>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18"/>
    </svg>
  </button>

  <main>
    {{ content | safe }}
  </main>

  <button
    class="back-to-top"
    type="button"
    aria-label="Voltar ao topo"
    data-back-to-top
    data-magnetic
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 13V3M3 8l5-5 5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <script src="/js/case-study-immersive.js?v={{ '/js/case-study-immersive.js' | assetVersion }}" defer></script>
  {% set motionContext = "immersive" %}
  {% include "partials/motion-scripts.njk" %}
</body>
</html>
