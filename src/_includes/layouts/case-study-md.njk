<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  {% include "partials/gtm-head.njk" %}
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/motion-head.njk" %}

  <!-- SEO Essencial -->
  <title>{{ title or metadata.title }}</title>
  <meta name="description" content="{{ description or metadata.description }}">
  <meta name="author" content="{{ metadata.author }}">
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">
  {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:type"        content="{{ ogType or 'website' }}">
  <meta property="og:url"         content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:title"       content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ description or metadata.description }}">
  <meta property="og:image"       content="{{ ogImage or metadata.ogImage }}">
  <meta property="og:image:alt"   content="{{ ogImageAlt or title or metadata.title }}">
  <meta property="og:locale"      content="pt_BR">
  <meta property="og:site_name"   content="{{ metadata.siteName }}">

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ title or metadata.title }}">
  <meta name="twitter:description" content="{{ description or metadata.description }}">
  <meta name="twitter:image"       content="{{ ogImage or metadata.ogImage }}">
  <meta name="twitter:image:alt"   content="{{ ogImageAlt or title or metadata.title }}">
  {% include "partials/structured-data.njk" %}
  {% set caseUrl = metadata.url + page.url %}
  {% set caseStudySchema = {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "@id": caseUrl + "#case-study",
    "name": title or metadata.title,
    "headline": title or metadata.title,
    "description": description or metadata.description,
    "url": caseUrl,
    "image": ogImage or metadata.ogImage,
    "inLanguage": "pt-BR",
    "creator": {
      "@id": metadata.url + "/#person"
    },
    "author": {
      "@id": metadata.url + "/#person"
    },
    "isPartOf": {
      "@id": metadata.url + "/projetos/#webpage"
    },
    "mainEntityOfPage": {
      "@id": caseUrl + "#webpage"
    },
    "keywords": metadata.areasOfExpertise
  } %}
  <script type="application/ld+json">{{ caseStudySchema | json | safe }}</script>

  <!-- Fonts: Montserrat -->
  <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/montserrat-latin-normal.woff2" crossorigin>

  <!-- Favicon -->
  <link rel="icon" type="image/webp" href="/assets/favicon.webp">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/reset.css?v={{ '/css/reset.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/vendor.lenis.css?v={{ '/css/vendor.lenis.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.tokens.css?v={{ '/css/style.tokens.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.nav.css?v={{ '/css/style.nav.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.footer-motion.css?v={{ '/css/style.footer-motion.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/case-study.core.css?v={{ '/css/case-study.core.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/case-study.projects.css?v={{ '/css/case-study.projects.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/case-study.extras.css?v={{ '/css/case-study.extras.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.case-redesign.css?v={{ '/css/style.case-redesign.css' | assetVersion }}">
  <link rel="stylesheet" href="/css/style.motion.css?v={{ '/css/style.motion.css' | assetVersion }}">
</head>
<body class="case-redesign">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K738G4S2"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  {% include "partials/transition-curtain.njk" %}

  {% include "partials/nav.njk" %}

  <main class="{{ bodyClass or 'cs-case-md' }}">
    <section class="cs-hero">
      <div class="cs-hero__inner">
        {% if heroStatus %}
          <span class="cs-hero__status">{{ heroStatus }}</span>
        {% endif %}
        <span class="cs-hero__tag">{{ heroTag }}</span>
        <h1 class="cs-hero__title">{{ projectName or title }}</h1>
        <p class="cs-hero__subtitle">{{ subtitle or description }}</p>
        {% if projectLinks %}
          <div class="cs-hero__links">
            {% for link in projectLinks %}
              <a href="{{ link.href }}" target="_blank" rel="noopener noreferrer">{{ link.label }}</a>
            {% endfor %}
          </div>
        {% endif %}
        <div class="cs-published-by">
          <img
            class="cs-published-by__avatar"
            src="/assets/perfil-floriano-avatar.webp"
            alt="Floriano Silva"
            loading="lazy"
            width="36"
            height="36"
          >
          <div class="cs-published-by__info">
            <p class="cs-published-by__label">Publicado por</p>
            <p class="cs-published-by__name">Floriano Silva</p>
          </div>
        </div>
      </div>
    </section>

    {% include "partials/case-overview.njk" %}

    {% if summary %}
      <div class="cs-summary">
        <div class="cs-summary__inner">
          <details>
            <summary class="cs-summary__toggle">
              <span>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                Resumo do projeto
              </span>
              <svg class="cs-summary__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="cs-summary__body">
              {% for item in summary %}
                <div class="cs-summary__item">
                  <span class="cs-summary__label">{{ item.label }}:</span>
                  <span class="cs-summary__text">{{ item.text | safe }}</span>
                </div>
              {% endfor %}
            </div>
          </details>
        </div>
      </div>
    {% endif %}

    {% if metrics %}
      <div class="cs-bignums">
        {% for item in metrics %}
          <div class="cs-bignum" data-animate{% if loop.index0 %} data-delay="{{ loop.index0 }}"{% endif %}>
            <div class="cs-bignum__head">
              {% if item.icon == "time" %}
                <svg class="cs-bignum__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {% elif item.icon == "calendar" %}
                <svg class="cs-bignum__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {% else %}
                <svg class="cs-bignum__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              {% endif %}
              <span class="cs-bignum__value">{{ item.value }}</span>
            </div>
            <span class="cs-bignum__label">{{ item.label }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <div class="cs-layout">
      <aside class="cs-toc" aria-label="Índice do case" data-cs-toc>
        <p class="cs-toc__title">Neste case</p>
        <nav aria-label="Seções do case">
          <ul class="cs-toc__list"></ul>
        </nav>
      </aside>
      <div class="cs-layout__body">
        {{ content | safe }}
      </div>
    </div>

    {% if learnings %}
      <section class="cs-learnings section" id="sec-aprendizados-finais" data-cs-section data-cs-label="Aprendizados finais">
        <div class="cs-container">
          <p class="cs-kicker-light">Aprendizados</p>
          <h2 class="section-title" data-animate>{{ learningsTitle or "O que este projeto prova" }}</h2>
          <div class="cs-learnings__list">
            {% for item in learnings %}
              <div class="cs-learning" data-animate{% if loop.index0 %} data-delay="{{ loop.index0 }}"{% endif %}>
                <span class="cs-learning__icon" aria-hidden="true">
                  {% if item.icon == "grid" %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  {% elif item.icon == "trend" %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                  {% else %}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  {% endif %}
                </span>
                <p class="cs-learning__text">{{ item.text | safe }}</p>
              </div>
            {% endfor %}
          </div>
        </div>
      </section>
    {% endif %}

    {% if roleGroups %}
      <section class="cs-role" id="sec-papel" data-cs-section data-cs-label="Papel">
        <div class="cs-container">
          <p class="cs-kicker-light">Como atuei no projeto</p>
          <div class="cs-role__groups">
            {% for group in roleGroups %}
              <div class="cs-role__group">
                <p class="cs-role__label">{{ group.label }}</p>
                <div class="cs-tags">
                  {% for tag in group.tags %}
                    <span class="cs-tag">{{ tag }}</span>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </section>
    {% endif %}

    {% if projectNav %}
      <nav class="cs-nav" aria-label="Navegação entre projetos">
        <div class="container cs-nav__inner">
          {% if projectNav.prev %}
            <a href="{{ projectNav.prev.href }}" class="cs-nav__link cs-nav__link--prev">
              <span class="cs-nav__direction">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ projectNav.prev.label or "Projeto anterior" }}
              </span>
              <span class="cs-nav__project">{{ projectNav.prev.title }}</span>
            </a>
          {% endif %}

          <a href="{{ projectNav.backHref or '/#projetos' }}" class="cs-nav__back">
            {{ projectNav.backLabel or "Todos os Projetos" }}
          </a>

          {% if projectNav.next %}
            <a href="{{ projectNav.next.href }}" class="cs-nav__link cs-nav__link--next">
              <span class="cs-nav__direction">
                {{ projectNav.next.label or "Próximo Projeto" }}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="cs-nav__project">{{ projectNav.next.title }}</span>
            </a>
          {% endif %}
        </div>
      </nav>
    {% endif %}
  </main>

  {% include "partials/case-next.njk" %}
  {% include "partials/footer.njk" %}

  <script src="/js/main.js?v={{ '/js/main.js' | assetVersion }}"></script>
  {% set motionContext = "case" %}
  {% include "partials/motion-scripts.njk" %}
</body>
</html>
