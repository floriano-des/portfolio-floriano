---
layout: base.njk
title: "Reflexões, Floriano Silva · Designer de experiências digitais"
description: "Artigos e reflexões sobre design, growth, comportamento, conversão, IA e experiência orientada a dados."
activeNav: reflexoes
schemaType: Blog
bodyClass: reflections-redesign
extraStylesheet: /css/style.periphery.css
---

  <!-- ================================================
       REFLEXÕES , LISTAGEM
       ================================================ -->
  <main class="reflections section page-top" id="reflexoes">
    <div class="container">

      <div class="reflections__heading" data-animate>
        <p class="section-kicker">Notas, artigos e provocações</p>
        <h1 class="page-title">Reflexões</h1>
      </div>

      <div class="reflections-table">
        <div class="reflections-table__head" aria-hidden="true">
          <span>Artigo</span>
          <span>Data</span>
        </div>

        {% if reflexoes.items.length %}
          {% for post in reflexoes.items %}
            <article class="reflection-row" data-animate>
              <a href="{{ post.url }}" class="reflection-row__link">
                <span class="reflection-row__index">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                <h2 class="reflection-row__title">{{ post.title }}</h2>
                {% if post.dateDisplay %}
                  <time class="reflection-row__date" datetime="{{ post.dateAttr }}">{{ post.dateDisplay }}</time>
                {% endif %}
                <span class="reflection-row__arrow" aria-hidden="true">↗</span>
              </a>
            </article>
          {% endfor %}
        {% else %}
          <p style="color: rgba(230,230,230,.5); grid-column: 1 / -1;">
            Nenhum artigo encontrado. Confira diretamente no
        <a href="https://medium.com/@floriano-des" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline;">Medium</a>.
          </p>
        {% endif %}

      </div>
    </div>
  </main>
