  <!-- ================================================
       HERO
       ================================================ -->
  <section class="hero" id="home">

    <div class="hero__container">

      <div class="hero__image" data-animate>
        <img
          src="/assets/perfil-floriano-hero.png"
          alt="Floriano Silva"
          width="900"
          height="900"
          loading="eager"
          fetchpriority="high"
          decoding="async"
