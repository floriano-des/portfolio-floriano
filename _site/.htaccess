# ============================================================
# .htaccess , floriano.des.br
# Hostinger usa LiteSpeed com suporte a diretivas Apache
# ============================================================

# Desativa listagem de diretórios
Options -Indexes

# ── Redirects 301 (migração WordPress → Eleventy) ────────────
# Posts antigos → /reflexoes
Redirect 301 /2025/06/o-que-aprendi-construindo-meu-primeiro-design-system-do-zero/ /reflexoes
Redirect 301 /2025/06/parece-carinho-e-empatia-mas-e-so-ux/ /reflexoes
Redirect 301 /2026/02/as-maquinas-ja-ganharam-de-humanos-nas-fabricas-voce-vai-cometer-o-mesmo-erro/ /reflexoes

# Páginas renomeadas
Redirect 301 /sobre-mim/ /sobre/
Redirect 301 /projetos-de-design/ /projetos/

# Projetos
Redirect 301 /olho-vivo/ /projetos/olho-vivo/
Redirect 301 /bit-system-design-system-da-dois-palitos-marketing/ /projetos/bit-system/
Redirect 301 /quantum-viz-ux-estrategico-copywriting-e-otimizacao-de-conversao/ /projetos/quantum-vizz/

# ── HTTPS + non-www ──────────────────────────────────────────
# Nota: a Hostinger geralmente já força HTTPS no painel.
# Mantenha ativo apenas se não houver conflito com as
# configurações do servidor.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Página 404 personalizada ─────────────────────────────────
ErrorDocument 404 /404.html

# ── Compressão GZIP / Deflate ────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ── Cache do navegador (mod_expires) ─────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: sem cache (garante sempre a versão mais recente)
  ExpiresByType text/html                 "access plus 0 seconds"

  # CSS e JS: 1 ano (invalidar via renomear arquivo ou query string)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"

  # Imagens
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fontes
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"
</IfModule>

# ── Cache via Cache-Control (mod_headers) ─────────────────────
<IfModule mod_headers.c>
  # Assets estáticos: cache de 1 ano, imutável
  <FilesMatch "\.(css|js|webp|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: sem cache
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ── Cabeçalhos de Segurança ──────────────────────────────────
<IfModule mod_headers.c>
  # Evita MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Evita que o site seja embarcado em iframes externos
  Header always set X-Frame-Options "SAMEORIGIN"

  # Força HTTPS por 1 ano (ative somente após confirmar HTTPS funcional)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Política de referência: envia origem completa apenas para mesmo domínio
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Desativa funcionalidades sensíveis do navegador que o site não usa
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Tipos MIME ───────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType font/woff2   .woff2
  AddType font/woff    .woff
  AddType image/webp   .webp
  AddType image/svg+xml .svg
</IfModule>
